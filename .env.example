# Copy this file to .env.local.

# Main model: DeepSeek. Normal requests use DeepSeek first.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Secondary model: Qwen. Used only after the DeepSeek call and retry both fail.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Optional developer fallback. Not part of the product main/secondary model workflow.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
